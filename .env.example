# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# .env.local is gitignored and loaded automatically via python-dotenv by
# both src/config.py and the dataset creation script.

# ── API keys ──────────────────────────────────────────────────────────────
# Anthropic (Claude models): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Moonshot / Kimi (optional): https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# Google is authenticated via ADC (not an env var):
#   gcloud auth application-default login

# ── MIMIC data paths (collaborator-specific) ──────────────────────────────
# Required only for dataset creation (MIMIC-IV-Ext-Creation.py).
# The creation script falls back to /data/local/llm-evaluation if unset.
MIMIC_DATA_ROOT=
MIMIC_IV_ED_DIR=
MIMIC_IV_PATIENTS_FILE=
MIMIC_IV_NOTE_DISCHARGE_FILE=
